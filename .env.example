# ── Pick one (or several). FreeAgent reads whichever matches the provider. ──

# z.ai — free GLM-4.5-flash + paid GLM-4.5/4.6 (https://z.ai)
ZAI_API_KEY=

# Groq — free tier with rate limits (https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter — many `:free` routes (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Google Gemini — free quota in AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI — paid (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic — paid, OpenAI-compat endpoint (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# xAI Grok — paid (https://console.x.ai)
XAI_API_KEY=

# Mistral — paid (https://console.mistral.ai)
MISTRAL_API_KEY=

# ── Defaults ──────────────────────────────────────────────────────────────
# FREEAGENT_PROVIDER=zai
# FREEAGENT_MODEL=glm-4.5-flash
# FREEAGENT_BASE_URL=
# FREEAGENT_STREAM=1
